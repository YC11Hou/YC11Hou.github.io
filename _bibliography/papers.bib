@article{yan2026aion,
  title     = {AION: Aerial Indoor Object-Goal Navigation Using Dual-Policy Reinforcement Learning},
  author    = {Yan, Zichen and Hou, Yuchen and Wang, Shenao and Gao, Yichao and Huang, Rui and Zhao, Lin},
  journal   = {arXiv preprint},
  year      = {2026},
  eprint    = {2601.15614},
  archiveprefix = {arXiv},
  arxiv     = {2601.15614},
  abbr      = {Preprint},
  abstract  = {We present AION, a zero-shot aerial indoor object-goal navigation system using dual-policy reinforcement learning. The system autonomously switches between exploration and target-driven navigation modes based on target visibility, leveraging RGB-D sensor input and CLIP-based multimodal features. The navigation policy is trained from scratch to master a discrete action space including take-off, navigation, and landing, and is deployed on autonomous drones using ROS 2 for real-time control.},
  selected  = {true},
  html      = {https://arxiv.org/abs/2601.15614}
}

@article{hou2026vla,
  title     = {LangGap: Diagnosing and Closing the Language Gap in Vision-Language-Action Models},
  author    = {Hou, Yuchen and Zhao, Lin},
  journal   = {arXiv preprint},
  year      = {2026},
  eprint    = {2603.00592},
  archiveprefix = {arXiv},
  arxiv     = {2603.00592},
  abbr      = {Preprint},
  abstract  = {We discover that state-of-the-art Vision-Language-Action models achieve high benchmark scores but ignore language instructions, revealing a gap between performance and true understanding. We design a systematic semantic perturbation evaluation framework to expose language grounding failures, and propose a multi-task same-scene training approach with an augmented dataset for fine-tuning.},
  selected  = {true},
  html      = {https://arxiv.org/abs/2603.00592}
}
