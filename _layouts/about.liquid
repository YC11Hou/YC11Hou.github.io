---
layout: default
---
<div class="post">
  <!-- Section 1: Banner -->
  <div class="about-banner">
    <div class="about-banner-left">
      {% assign profile_image_path = 'assets/img/prof_pic_web.jpg' %}
      {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
      {%
        include figure.liquid loading="eager" path=profile_image_path class=profile_image_class alt="Yuchen Hou"
        cache_bust=true
      %}
      <h1 class="banner-name">
        {% if site.title == 'blank' %}
          <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }} {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>
      <p class="banner-subtitle">{{ page.subtitle }}</p>
      <div class="banner-tags">
        <span class="banner-tag">NUS Advanced Control Lab</span>
        <span class="banner-tag">Embodied AI & Robotics</span>
      </div>
    </div>
    <div class="about-banner-right">
      <div class="quote-card">
        <p class="quote-text">"The darkest hour is just before the dawn."</p>
      </div>
    </div>
  </div>

  <article>
    <!-- Section 2: About Me -->
    <h2>About Me</h2>
    <div class="clearfix">{{ content }}</div>

    <!-- Section 3: Contact -->
    <h2>Contact</h2>
    <div class="about-contact">
      {% if site.data.socials.email %}
        <div class="contact-item">
          <i class="fa-solid fa-envelope"></i>
          <a href="mailto:{{ site.data.socials.email }}">{{ site.data.socials.email }}</a>
        </div>
      {% endif %}
      {% if site.data.socials.github_username %}
        <div class="contact-item">
          <i class="fa-brands fa-github"></i>
          <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" rel="noopener noreferrer">github.com/{{ site.data.socials.github_username }}</a>
        </div>
      {% endif %}
      {% if site.data.socials.linkedin_username %}
        <div class="contact-item">
          <i class="fa-brands fa-linkedin"></i>
          <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" rel="noopener noreferrer">linkedin.com/in/{{ site.data.socials.linkedin_username }}</a>
        </div>
      {% endif %}
    </div>

    <!-- Section 4: News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
